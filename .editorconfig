# EditorConfig: https://editorconfig.org

# top-most EditorConfig file
root = true

[*]
charset = utf-8
end_of_line = lf
spelling_language = en-US
indent_style = space
indent_size = 4
trim_trailing_whitespace = true
insert_final_newline = true

[.git*]
indent_style = tab
indent_size = tab
trim_trailing_whitespace = unset
insert_final_newline = unset

[*.txt]
indent_style = unset
indent_size = unset
trim_trailing_whitespace = unset
insert_final_newline = unset

[*.sh]
indent_style = space
indent_size = 2
trim_trailing_whitespace = false
insert_final_newline = false
max_line_length = 80
shell_variant = bash

[*.{cmd,bat,ps1}]
end_of_line = crlf

[{Makefile,*.mk}]
indent_style = tab
indent_size = 4
trim_trailing_whitespace = false
insert_final_newline = false

[{{j,J}ustfile,.justfile,.justfile.user}]
indent_style = space
indent_size = 4
trim_trailing_whitespace = false
insert_final_newline = false

[{{Docker,Container}file,*.{Docker,Container}file}]
indent_style = space
indent_size = 4

[*.{py,pyi}]
charset = utf-8
end_of_line = lf
indent_style = space
indent_size = 4
trim_trailing_whitespace = true
insert_final_newline = true
max_line_length = 100
docstring_fill_column = 99 # Docstring line wrapping

[.venvs/**.py]
indent_size = unset
indent_style = unset
trim_trailing_whitespace = unset
insert_final_newline = unset
end_of_line = unset

[*.rb]
indent_style = space
indent_size = 2

[*.php]
indent_style = space
indent_size = 4

[*.{pl,pm}]
charset = utf-8
end_of_line = lf
indent_style = space
indent_size = 4
trim_trailing_whitespace = true
insert_final_newline = true

[*.{js,jsx,mjs,coffee,bun}]
indent_style = space
indent_size = 2
quote_type = single

[*.{ts,tsx}]
indent_style = space
indent_size = 2

[node_modules/**.js]
indent_size = unset
indent_style = unset
trim_trailing_whitespace = unset
insert_final_newline = unset
end_of_line = unset

[*.rs]
indent_style = space
indent_size = 4
insert_final_newline = false
trim_trailing_whitespace = true
max_line_length = 100

[tests/**/*.rs]
charset = utf-8
indent_size = unset
indent_style = unset
trim_trailing_whitespace = unset
insert_final_newline = unset
end_of_line = unset

[*.{json,json{c,5}}]
indent_style = space
indent_size = 2
insert_final_newline = false

[package.json]
indent_style = space
indent_size = 2

[{*.tf,*.tfvars,*.tf.json}]
indent_style = space
indent_size = 2

[{*.pkr.hcl,*.pkr.hcl.json}]
indent_style = space
indent_size = 2

[*.{yaml,yml,yamllint}]
indent_style = space
indent_size = 2
trim_trailing_whitespace = true
insert_final_newline = false

[*.toml]
indent_style = space
indent_size = 4
trim_trailing_whitespace = true
insert_final_newline = false
max_line_length = 80

[*.{xml,plist}]
indent_style = space
indent_size = 2
insert_final_newline = ignore

[*.{csv,tsv}]
indent_style = space
indent_size = 4
tab_width = 4
trim_trailing_whitespace = false
insert_final_newline = true

[*.graphql]
indent_style = space
indent_size = 2

[*.{htm1,htm}]
indent_style = space
indent_size = 2
trim_trailing_whitespace = true

[*.css]
indent_style = space
indent_size = 2
trim_trailing_whitespace = true

[*.{md,mdx,markdown,mkdn}]
indent_style = space
indent_size = 2
insert_final_newline = false
max_line_length = 120

[LICENSE]
indent_style = unset
indent_size = unset
trim_trailing_whitespace = unset
insert_final_newline = unset

[*.{bazel,bzl}]
indent_size = 4
indent_style = space

[*.{ini,cfg}]
indent_style = space
indent_size = 4
trim_trailing_whitespace = false
insert_final_newline = true

[*.less]
indent_style = space
indent_size = 2

#[*.{diff,patch}]
#trim_trailing_whitespace = false
#insert_final_newline = false
